
{
  type: "recv",                       // 支持send recv 两种模式
  syncTime: 0,                        // 同步周期, 单位毫秒,不低于1000毫秒, 0 则不会记录offset
  sendInterval : 5000,                // send模式的发送频率, 单位ms, 模拟发送数据时使用
  sendQueueSize: 1,                   // send模式的缓冲队列大小, 仅发送模式时有效, 默认值1024, 必须为2的幂, 例如 2 4 8 16 32 ...
  dumpHex: false,                     // 数据包是否为hexString格式; recv模式时体现在日志中; send模式时,表示 `sendFile` 中的格式是否为hexString格式
  resetTimestamp: false,              // 有标准点数据时, 重置时间戳为发送当前时间

  log: {
    logLevel: -1,                     // 日志等级, (DebugLevel=-1; InfoLevel=0, WarnLevel=1; ErrorLevel=2; DPanicLevel=3; PanicLevel=4; FatalLevel=5)
    colorful: false,                  // 是否需要彩色
    maxAge: 72,                       // 日志最长保留时间, 单位 小时
    maxSize: 10737418240,             // 单文件最大滚动大小, 单位 byte, 超过后强制滚动, 10G
    rotationTime: 24,                 // 日志滚动周期, 单位 小时, 24小时滚动一个文件
    console: true,                    // 是否同时输出到控制台
    async: false,                     // 是否异步输出到日志文件
    flushInterval: 2000,              // 异步输出日志缓冲区刷新间隔, 单位为毫秒, 默认为1s
    bufferSize: 4194304,              // 异步输出日志缓冲区大小, 单位为字节, 默认4M
    logDir: "logs",                   // 日志路径
  },

  source: [
    {
      type: "redismq",
      isCompress: false, // 是否压缩
      mq: {
        addrs: ["127.0.0.1:16379"],
        retry: 500,                   // 连接失败时重试次数, 若retry值为-1, 则无限重试
        password: "WuTz@DtXyTeCh.com",

        dbNum: 0,                     // redis数据库编号
        subscribeFlag: 1,             // 订阅标记 0: 不订阅; 1: 使用 `channels`列表订阅指定channel; 2: 订阅全部频道; 0或2时 忽略 `channels` 字段
        topics: ["sim_data"],         // 需要同步的频道编号
      },
    },
  ],

  target: []
}